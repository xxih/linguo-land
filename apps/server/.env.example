# 拷贝到 apps/server/.env 后填好对应值。
# 没设 JWT_SECRET / JWT_REFRESH_SECRET 时 server 拒绝启动。

# --- 数据库 ---
# 方案 A：macOS 原生 Homebrew Postgres（dev 机器推荐）
#   brew services start postgresql@16 && createdb lang_lang_land
DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/lang_lang_land
# 方案 B：仓库根的 docker compose（端口 5433，密码 "password"）
#   docker-compose up -d
# DATABASE_URL=postgresql://postgres:password@localhost:5433/lang_lang_land

# --- JWT（必填） ---
# 用强随机值，例如：openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-48-byte-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-48-byte-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS ---
# 逗号分隔的白名单。chrome-extension://* 始终放行；NODE_ENV != production 时
# localhost 自动放行。这里登记额外的 web 来源（比如未来要加的管理后台）。
# CORS_ORIGINS=

# --- AI 字典回退 ---
# 阿里云 DashScope（百炼）API key，DB 没命中的词通过它兜底。
DASHSCOPE_API_KEY=

# --- 运行时 ---
PORT=3000
# NODE_ENV=development
