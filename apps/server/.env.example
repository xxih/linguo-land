# Copy to apps/server/.env and fill in the values.
# The server refuses to boot without JWT_SECRET / JWT_REFRESH_SECRET.

# --- Database ---
# Option A: native Homebrew Postgres on macOS (recommended on dev machines):
#   brew services start postgresql@16 && createdb lang_lang_land
DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/lang_lang_land
# Option B: Docker compose at repo root (port 5433, password "password"):
#   docker-compose up -d
# DATABASE_URL=postgresql://postgres:password@localhost:5433/lang_lang_land

# --- JWT (REQUIRED) ---
# Generate strong random values, e.g.: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-48-byte-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-48-byte-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS ---
# Comma-separated allowlist. chrome-extension://* is always allowed; localhost is
# allowed automatically when NODE_ENV != production. Add explicit web origins
# here if/when they exist.
# CORS_ORIGINS=

# --- AI dictionary fallback ---
# DashScope (Aliyun) API key for the AI definition fallback when DB lookup misses.
DASHSCOPE_API_KEY=

# --- Runtime ---
PORT=3000
# NODE_ENV=development
